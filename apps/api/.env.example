# Copie para .env na mesma pasta:  cp .env.example .env  (ou rode pnpm setup:local na raiz)
# Banco local (docker compose na raiz do monorepo — porta 5434 no host)
DATABASE_URL=postgresql://obra:obra_dev_local@localhost:5434/obra_dupla

# Opcional: só para `prisma migrate` com Supabase (conexão direta 5432). Local não precisa.
# Produção Supabase (Obra Dupla — Project ID fixo): a senha vem do painel Database.
# DATABASE_URL_DIRECT=postgresql://postgres:[SENHA]@db.aizrqqdgzzforgvxzybe.supabase.co:5432/postgres?sslmode=require
# Pooler (ex.: 6543) — mesmo Project ID no user; host copia do painel Supabase.
# DATABASE_URL=postgresql://postgres.aizrqqdgzzforgvxzybe:[SENHA]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

JWT_SECRET=obra-dupla-dev-secret-change-in-production

PORT=3005
HOST=0.0.0.0

# Limite do body JSON (default na API: 6mb). Render free: não aumentar sem necessidade.
# JSON_BODY_LIMIT=6mb

# Login de desenvolvimento (seed: pnpm -C apps/api db:seed)
DEV_USER_PASSWORD=123456

# Cadastro público (POST /auth/register)
PUBLIC_REGISTRATION_ENABLED=true
TRIAL_DAYS=14
PLAN_FREE_MAX_JOBSITES=5
PLAN_FREE_MAX_USERS=5

# Anexos: sem R2 e sem Supabase, a API grava base64 no PostgreSQL (ok para dev).
# Cloudflare R2 (opcional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Supabase Storage (opcional)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
