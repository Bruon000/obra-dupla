// https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id            String          @id @default(uuid())
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  users         User[]
  clients       Client[]
  jobSites      JobSite[]
  quotes        Quote[]
  jobCostEntries       JobCostEntry[]
  jobCostAttachments   JobCostAttachment[]
  jobSiteMembers      JobSiteMember[]
  jobSiteDocuments    JobSiteDocument[]
  activityEvents       ActivityEvent[]
  customFields  CustomField[]
  workflows     Workflow[]
  templates     Template[]
  syncDevices   SyncDevice[]
  syncConflicts SyncConflict[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdJobCostEntries   JobCostEntry[]        @relation("JobCostEntryCreatedBy")
  updatedJobCostEntries   JobCostEntry[]        @relation("JobCostEntryUpdatedBy")
  deletedJobCostEntries   JobCostEntry[]        @relation("JobCostEntryDeletedBy")

  createdJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentCreatedBy")
  updatedJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentUpdatedBy")
  deletedJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentDeletedBy")

  activityEvents ActivityEvent[]

  createdJobSiteMembers      JobSiteMember[]      @relation("JobSiteMemberCreatedBy")
  updatedJobSiteMembers      JobSiteMember[]      @relation("JobSiteMemberUpdatedBy")
  deletedJobSiteMembers      JobSiteMember[]      @relation("JobSiteMemberDeletedBy")

  createdJobSiteDocuments    JobSiteDocument[]    @relation("JobSiteDocumentCreatedBy")
  updatedJobSiteDocuments    JobSiteDocument[]    @relation("JobSiteDocumentUpdatedBy")
  deletedJobSiteDocuments    JobSiteDocument[]    @relation("JobSiteDocumentDeletedBy")

  // Participação da obra (sócios).
  jobSiteMembers JobSiteMember[] @relation("JobSiteMemberUser")
}

model Client {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobSite {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  title        String
  address      String      @default("")
  notes        String      @default("")
  status       String      @default("EM_ANDAMENTO")
  startDate    DateTime?   @db.Date
  endDate      DateTime?   @db.Date
  saleValue    Decimal     @default(0) @db.Decimal(14, 2)

  deletedAt    DateTime?

  quotes       Quote[]
  costEntries  JobCostEntry[]
  customFieldValues CustomFieldValue[]

  jobSiteMembers   JobSiteMember[]   @relation("JobSiteMemberJobSite")
  jobSiteDocuments JobSiteDocument[] @relation("JobSiteDocumentJobSite")

  @@index([companyId, deletedAt, createdAt])
}

model Quote {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobSiteId String
  jobSite   JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)
}

model CustomField {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  jobSiteId String
  jobSite   JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)
}

model Workflow {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SyncDevice {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SyncConflict {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobCostEntry {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobSiteId       String
  jobSite         JobSite   @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)

  date            DateTime
  source          String
  category        String
  // "Material" vs "Serviço" (e afins). Usamos este campo no resumo de obra.
  costType        String    @default("Material")
  description     String
  weekLabel       String?
  quantity        Decimal?  @db.Decimal(14, 3)
  unitPrice       Decimal?  @db.Decimal(14, 2)
  totalAmount     Decimal   @db.Decimal(14, 2)
  payer           String
  supplier        String?
  invoiceNumber   String?
  paymentMethod   String?
  notes           String?

  version         Int       @default(1)
  deviceId        String?
  lastSyncedAt    DateTime?
  deletedAt       DateTime?

  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?

  createdByUser   User?     @relation("JobCostEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?     @relation("JobCostEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser   User?     @relation("JobCostEntryDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  attachments     JobCostAttachment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, jobSiteId, deletedAt])
  @@index([companyId, payer, deletedAt])
  @@index([companyId, source, deletedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
}

model JobCostAttachment {
  id               String       @id @default(uuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobCostEntryId   String
  jobCostEntry     JobCostEntry @relation(fields: [jobCostEntryId], references: [id], onDelete: Cascade)

  fileName         String
  mimeType         String
  storageType      String
  fileDataBase64   String?
  fileUrl          String?
  thumbnailBase64  String?

  version          Int          @default(1)
  deviceId         String?
  lastSyncedAt     DateTime?
  deletedAt        DateTime?

  createdByUserId  String?
  updatedByUserId  String?
  deletedByUserId  String?

  createdByUser    User?        @relation("JobCostAttachmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?        @relation("JobCostAttachmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?        @relation("JobCostAttachmentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([companyId, jobCostEntryId, deletedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
}

model ActivityEvent {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  eventType  String
  entityType String
  entityId   String
  payload    Json?

  createdAt  DateTime @default(now())

  @@index([companyId, entityType, entityId, createdAt])
  @@index([companyId, createdAt])
  @@index([userId])
}

model JobSiteMember {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobSiteId     String
  jobSite       JobSite   @relation("JobSiteMemberJobSite", fields: [jobSiteId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation("JobSiteMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  // Mantemos snapshot do nome para deixar trilha de auditoria mais útil.
  name          String
  sharePercent Decimal   @db.Decimal(6, 2)
  sortIndex     Int       @default(0)

  version       Int       @default(1)

  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdByUserId  String?
  updatedByUserId  String?
  deletedByUserId  String?

  createdByUser    User?     @relation("JobSiteMemberCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?     @relation("JobSiteMemberUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?     @relation("JobSiteMemberDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, jobSiteId, deletedAt, sortIndex])
  @@index([companyId, userId, deletedAt])
}

model JobSiteDocument {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobSiteId     String
  jobSite       JobSite  @relation("JobSiteDocumentJobSite", fields: [jobSiteId], references: [id], onDelete: Cascade)

  category      String
  title         String

  fileName      String
  mimeType      String
  storageType   String
  fileDataBase64 String?
  fileUrl       String?
  thumbnailBase64 String?

  uploadedByUserId String?
  createdByUserId  String?
  updatedByUserId  String?
  deletedByUserId  String?

  createdByUser  User?  @relation("JobSiteDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser  User?  @relation("JobSiteDocumentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser  User?  @relation("JobSiteDocumentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  version        Int      @default(1)
  deviceId       String?
  lastSyncedAt   DateTime?

  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, jobSiteId, deletedAt, createdAt])
  @@index([companyId, uploadedByUserId])
}
