// https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String          @id @default(uuid())
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  users         User[]
  clients       Client[]
  jobSites      JobSite[]
  quotes        Quote[]
  jobCostEntries       JobCostEntry[]
  jobCostAttachments   JobCostAttachment[]
  customFields  CustomField[]
  workflows     Workflow[]
  templates     Template[]
  syncDevices   SyncDevice[]
  syncConflicts SyncConflict[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdJobCostEntries   JobCostEntry[]        @relation("JobCostEntryCreatedBy")
  updatedJobCostEntries   JobCostEntry[]        @relation("JobCostEntryUpdatedBy")
  deletedJobCostEntries   JobCostEntry[]        @relation("JobCostEntryDeletedBy")

  createdJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentCreatedBy")
  updatedJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentUpdatedBy")
  deletedJobCostAttachments JobCostAttachment[] @relation("JobCostAttachmentDeletedBy")
}

model Client {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobSite {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  quotes       Quote[]
  costEntries  JobCostEntry[]
  customFieldValues CustomFieldValue[]
}

model Quote {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobSiteId String
  jobSite   JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)
}

model CustomField {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  jobSiteId String
  jobSite   JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)
}

model Workflow {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SyncDevice {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SyncConflict {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobCostEntry {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobSiteId       String
  jobSite         JobSite   @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)

  date            DateTime
  source          String
  category        String
  description     String
  weekLabel       String?
  quantity        Decimal?  @db.Decimal(14, 3)
  unitPrice       Decimal?  @db.Decimal(14, 2)
  totalAmount     Decimal   @db.Decimal(14, 2)
  payer           String
  supplier        String?
  invoiceNumber   String?
  paymentMethod   String?
  notes           String?

  version         Int       @default(1)
  deviceId        String?
  lastSyncedAt    DateTime?
  deletedAt       DateTime?

  createdByUserId String?
  updatedByUserId String?
  deletedByUserId String?

  createdByUser   User?     @relation("JobCostEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?     @relation("JobCostEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser   User?     @relation("JobCostEntryDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  attachments     JobCostAttachment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, jobSiteId, deletedAt])
  @@index([companyId, payer, deletedAt])
  @@index([companyId, source, deletedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
}

model JobCostAttachment {
  id               String       @id @default(uuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobCostEntryId   String
  jobCostEntry     JobCostEntry @relation(fields: [jobCostEntryId], references: [id], onDelete: Cascade)

  fileName         String
  mimeType         String
  storageType      String
  fileDataBase64   String?
  fileUrl          String?
  thumbnailBase64  String?

  version          Int          @default(1)
  deviceId         String?
  lastSyncedAt     DateTime?
  deletedAt        DateTime?

  createdByUserId  String?
  updatedByUserId  String?
  deletedByUserId  String?

  createdByUser    User?        @relation("JobCostAttachmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?        @relation("JobCostAttachmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?        @relation("JobCostAttachmentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([companyId, jobCostEntryId, deletedAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedByUserId])
}
